<?xml version="1.0"?>

<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services https://symfony.com/schema/dic/services/services-1.0.xsd">

    <services>
        <defaults autowire="true" autoconfigure="true" public="false" />

        <prototype
            namespace="SZ\ProductTypeExtension\"
            resource="../../*"
            exclude="../../{DependencyInjection,Resources,Tests,Kernel.php}" />

        <service
            id="SZ\ProductTypeExtension\Core\Content\ProductTypeExtension\ProductTypeExtensionDefinition">
            <tag name="shopware.entity.definition" entity="sz_product_type_extension" />
        </service>

        <service id="SZ\ProductTypeExtension\Core\Content\ProductTypeExtension\ProductExtension">
            <tag name="shopware.entity.extension" />
        </service>

        <service id="SZ\ProductTypeExtension\Core\Content\ProductTypeExtension\SalesChannelProductExtension">
            <tag name="shopware.entity.extension" />
        </service>

        <service id="SZ\ProductTypeExtension\Elasticsearch\Product\ElasticsearchProductDefinitionDecorator"
                 decorates="Shopware\Elasticsearch\Product\ElasticsearchProductDefinition">
            <argument type="service" id="SZ\ProductTypeExtension\Elasticsearch\Product\ElasticsearchProductDefinitionDecorator.inner" />
            <argument type="service" id="Doctrine\DBAL\Connection" />
        </service>
    </services>
</container>